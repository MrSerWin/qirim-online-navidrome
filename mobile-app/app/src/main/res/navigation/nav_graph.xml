<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="online.qirim.music.ui.fragment.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="online.qirim.music.ui.fragment.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_player"
            app:destination="@id/playerFragment" />
        <action
            android:id="@+id/action_home_to_album"
            app:destination="@id/albumDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="online.qirim.music.ui.fragment.SearchFragment"
        android:label="Search">
        <action
            android:id="@+id/action_search_to_album"
            app:destination="@id/albumDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/libraryFragment"
        android:name="online.qirim.music.ui.fragment.LibraryFragment"
        android:label="Library">
        <action
            android:id="@+id/action_library_to_album"
            app:destination="@id/albumDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="online.qirim.music.ui.fragment.SettingsFragment"
        android:label="Settings">
        <action
            android:id="@+id/action_settings_to_login"
            app:destination="@id/loginFragment" />
    </fragment>

    <fragment
        android:id="@+id/playerFragment"
        android:name="online.qirim.music.ui.fragment.PlayerFragment"
        android:label="Player" />

    <fragment
        android:id="@+id/albumDetailFragment"
        android:name="online.qirim.music.ui.fragment.AlbumDetailFragment"
        android:label="Album">
        <argument
            android:name="albumId"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/wrappedFragment"
        android:name="online.qirim.music.ui.fragment.WrappedFragment"
        android:label="Wrapped" />

</navigation>
