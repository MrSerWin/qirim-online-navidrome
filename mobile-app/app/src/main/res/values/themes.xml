<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base QO Music Theme (Light) -->
    <style name="Theme.QOMusic" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/qo_primary</item>
        <item name="colorPrimaryDark">@color/qo_primary_dark</item>
        <item name="colorAccent">@color/qo_accent</item>
        <item name="colorOnPrimary">@color/qo_on_primary</item>
        <item name="android:colorBackground">@color/qo_background_light</item>
        <item name="colorSurface">@color/qo_surface_light</item>
        <item name="colorOnBackground">@color/qo_on_background_light</item>
        <item name="colorOnSurface">@color/qo_on_surface_light</item>
        <item name="android:statusBarColor">@color/qo_primary_dark</item>
        <item name="android:navigationBarColor">@color/qo_surface_light</item>
        <item name="android:fontFamily">@font/rajdhani</item>
    </style>

    <!-- Splash Screen Theme -->
    <style name="Theme.QOMusic.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/qo_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.QOMusic</item>
    </style>

    <!-- Text Styles -->
    <style name="QOText.Heading" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/rajdhani_bold</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
    </style>

    <style name="QOText.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">@font/rajdhani_bold</item>
        <item name="android:textColor">?attr/colorOnBackground</item>
    </style>

    <style name="QOText.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/rajdhani</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="QOText.Player" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/rajdhani_medium</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <!-- Button Styles -->
    <style name="QOButton.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/qo_primary</item>
        <item name="android:textColor">@color/qo_on_primary</item>
        <item name="android:fontFamily">@font/rajdhani_bold</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="QOButton.OAuth" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:fontFamily">@font/rajdhani_medium</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="QOButton.Guest" parent="Widget.Material3.Button.TextButton">
        <item name="android:fontFamily">@font/rajdhani_medium</item>
        <item name="android:textColor">@color/qo_primary</item>
    </style>

    <!-- Card Style -->
    <style name="QOCard.Album" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
    </style>

</resources>
